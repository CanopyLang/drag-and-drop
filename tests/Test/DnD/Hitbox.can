module Test.DnD.Hitbox exposing (main, tests)

import Basics exposing (..)
import Maybe exposing (..)
import List
import DnD.Hitbox exposing (..)
import Test exposing (..)
import Expect


main : Test
main =
    tests


tests : Test
tests =
    describe "DnD.Hitbox"
        [ closestEdgeTests
        , closestEdgeFilteredTests
        , zoneTests
        , zoneWithThresholdsTests
        , attachExtractTests
        ]


rect100 : { x : Float, y : Float, width : Float, height : Float }
rect100 =
    { x = 0, y = 0, width = 100, height = 100 }


closestEdgeTests : Test
closestEdgeTests =
    describe "closestEdge"
        [ test "point near top edge returns Top" <|
            \() ->
                closestEdge { x = 50, y = 2 } rect100
                    |> Expect.equal Top
        , test "point near bottom edge returns Bottom" <|
            \() ->
                closestEdge { x = 50, y = 98 } rect100
                    |> Expect.equal Bottom
        , test "point near left edge returns Left" <|
            \() ->
                closestEdge { x = 2, y = 50 } rect100
                    |> Expect.equal Left
        , test "point near right edge returns Right" <|
            \() ->
                closestEdge { x = 98, y = 50 } rect100
                    |> Expect.equal Right
        , test "point at top-left corner returns Top or Left" <|
            \() ->
                let
                    edge =
                        closestEdge { x = 1, y = 1 } rect100
                in
                Expect.true "should be Top or Left"
                    (edge == Top || edge == Left)
        , test "point at center is closest to some edge" <|
            \() ->
                let
                    edge =
                        closestEdge { x = 50, y = 50 } rect100
                in
                Expect.true "should be a valid edge"
                    (edge == Top || edge == Bottom || edge == Left || edge == Right)
        , test "point on exact top edge returns Top" <|
            \() ->
                closestEdge { x = 50, y = 0 } rect100
                    |> Expect.equal Top
        , test "offset rect: point near top" <|
            \() ->
                closestEdge { x = 150, y = 102 } { x = 100, y = 100, width = 100, height = 100 }
                    |> Expect.equal Top
        ]


closestEdgeFilteredTests : Test
closestEdgeFilteredTests =
    describe "closestEdgeFiltered"
        [ test "filters to Left and Right only" <|
            \() ->
                closestEdgeFiltered [ Left, Right ] { x = 2, y = 2 } rect100
                    |> Expect.equal Left
        , test "filters to Top and Bottom only" <|
            \() ->
                closestEdgeFiltered [ Top, Bottom ] { x = 2, y = 2 } rect100
                    |> Expect.equal Top
        , test "single edge always returns that edge" <|
            \() ->
                closestEdgeFiltered [ Right ] { x = 2, y = 2 } rect100
                    |> Expect.equal Right
        , test "empty filter list returns Top as default" <|
            \() ->
                closestEdgeFiltered [] { x = 50, y = 98 } rect100
                    |> Expect.equal Top
        ]


zoneTests : Test
zoneTests =
    describe "zone"
        [ test "point in top quarter returns TopQuarter" <|
            \() ->
                zone { x = 50, y = 10 } rect100
                    |> Expect.equal TopQuarter
        , test "point in center returns Center" <|
            \() ->
                zone { x = 50, y = 50 } rect100
                    |> Expect.equal Center
        , test "point in bottom quarter returns BottomQuarter" <|
            \() ->
                zone { x = 50, y = 90 } rect100
                    |> Expect.equal BottomQuarter
        , test "point at exact boundary of top zone" <|
            \() ->
                zone { x = 50, y = 24 } rect100
                    |> Expect.equal TopQuarter
        ]


zoneWithThresholdsTests : Test
zoneWithThresholdsTests =
    describe "zoneWithThresholds"
        [ test "larger top threshold captures more area" <|
            \() ->
                zoneWithThresholds 0.5 0.25 { x = 50, y = 40 } rect100
                    |> Expect.equal TopQuarter
        , test "larger bottom threshold captures more area" <|
            \() ->
                zoneWithThresholds 0.25 0.5 { x = 50, y = 60 } rect100
                    |> Expect.equal BottomQuarter
        , test "zero height rect returns Center" <|
            \() ->
                zoneWithThresholds 0.25 0.25 { x = 50, y = 0 } { x = 0, y = 0, width = 100, height = 0 }
                    |> Expect.equal Center
        , test "equal thresholds summing to 1 leave no center" <|
            \() ->
                zoneWithThresholds 0.5 0.5 { x = 50, y = 50 } rect100
                    |> Expect.equal BottomQuarter
        ]


attachExtractTests : Test
attachExtractTests =
    describe "attachClosestEdge / extractClosestEdge"
        [ test "round-trip Top" <|
            \() ->
                attachClosestEdge Top []
                    |> extractClosestEdge
                    |> Expect.equal (Just Top)
        , test "round-trip Bottom" <|
            \() ->
                attachClosestEdge Bottom []
                    |> extractClosestEdge
                    |> Expect.equal (Just Bottom)
        , test "round-trip Left" <|
            \() ->
                attachClosestEdge Left []
                    |> extractClosestEdge
                    |> Expect.equal (Just Left)
        , test "round-trip Right" <|
            \() ->
                attachClosestEdge Right []
                    |> extractClosestEdge
                    |> Expect.equal (Just Right)
        , test "extract from empty list returns Nothing" <|
            \() ->
                extractClosestEdge []
                    |> Expect.equal Nothing
        , test "extract from unrelated data returns Nothing" <|
            \() ->
                extractClosestEdge [ ( "foo", "bar" ), ( "baz", "qux" ) ]
                    |> Expect.equal Nothing
        , test "attach preserves existing data" <|
            \() ->
                let
                    data =
                        attachClosestEdge Top [ ( "key", "value" ) ]
                in
                Expect.true "should contain original pair"
                    (List.any (\( k, v ) -> k == "key" && v == "value") data)
        , test "extract ignores invalid edge string" <|
            \() ->
                extractClosestEdge [ ( "closestEdge", "diagonal" ) ]
                    |> Expect.equal Nothing
        ]
